# Supabase は Python からは使いません。Cursor の Supabase MCP で DB 操作してください。
# （参考）https://supabase.com/docs/guides/getting-started/mcp
ANTHROPIC_API_KEY=
SLACK_WEBHOOK_URL=
AGENT1_OUTPUT_PATH=../agent1/output/output_for_agent2.json
# ローカル検証例: AGENT1_OUTPUT_PATH=fixtures/sample_input.json

# 自然言語のみで1件実行する例（CLI / デモの natural_language モードと併用可）
# AGENT2_NATURAL_LANGUAGE=在宅向けのマッサージガンを売りたい

# Google スプレッドシート（任意・未設定なら追記スキップ）
# サービスアカウントJSONのパス。スプレッドシートをそのSAのメールに共有すること。
# GOOGLE_SHEETS_CREDENTIALS_PATH=C:\secrets\service_account.json
# GOOGLE_SHEET_ID=スプレッドシートURLの /d/ と /edit の間のID
# GOOGLE_SHEET_WORKSHEET=agent2_briefs
# 旧レイアウトのシートがある場合、自動で agent2_briefs_v2_structured タブに追記されることがあります。
